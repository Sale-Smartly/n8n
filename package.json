{
  "name": "n8n-nodes-salesmartly-npm",
  "version": "0.1.1",
  "author": {
    "name": "SaleSmartly",
    "email": "techservices@salesmartly.com"
  },
  "description": "n8n community nodes for SaleSmartly",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node ./node_modules/typescript/bin/tsc -p tsconfig.json && node scripts/copy-assets.js",
    "prepack": "npm run build",
    "test": "npm run build && node --test dist/test/*.test.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "n8n-core": ">=1.0.0",
    "n8n-workflow": ">=1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "n8n-workflow": ">=1.0.0",
    "typescript": "^5.7.3"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/SaleSmartlyApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/SaleSmartly/SaleSmartly.node.js",
      "dist/nodes/SaleSmartly/SaleSmartlyMessageTrigger.node.js"
    ]
  }
}
